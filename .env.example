# OpenMe environment example
#
# Copy this file to .env for local development. In production, set these values
# in each hosting provider's environment variable UI instead of committing them.

# ---------------------------------------------------------------------------
# Local development defaults
# ---------------------------------------------------------------------------

# Local Docker Compose Postgres. In production, DATABASE_URL should come from
# the production Postgres provider such as Neon or Supabase.
DATABASE_URL="postgresql://openme:openme@localhost:5432/openme_dev"

NODE_ENV="development"

# WEB_URL is the deployed frontend URL in production. Locally, it is the Next.js
# dev server and is also used by the API as the allowed CORS origin.
WEB_URL="http://localhost:3000"

# API_URL is the deployed API URL in production. Locally, it is the Express API.
API_URL="http://localhost:4000"

# NEXT_PUBLIC_API_URL is safe to expose because it is a public browser URL.
# Next.js reads this at build time, so production builds must set it correctly.
NEXT_PUBLIC_API_URL="http://localhost:4000"

# AI can stay disabled for the first production deploy.
AI_ENABLED="false"

# AI_SERVICE_URL should be the deployed AI service URL if AI_ENABLED=true.
AI_SERVICE_URL="http://localhost:8000"

# Optional shared secret for API-to-AI calls. Set the same value on apps/api and
# apps/ai-service in production. Do not expose it to the frontend. The AI
# service health endpoint remains public.
AI_SERVICE_TOKEN=""

# AI_PROVIDER=mock does not call Groq. Use AI_PROVIDER=groq only on the AI
# service when GROQ_API_KEY is configured.
AI_PROVIDER="mock"

# GROQ_API_KEY must never be exposed to the frontend. Set it only on the
# AI service when AI_PROVIDER=groq.
GROQ_API_KEY=""
GROQ_MODEL="llama-3.3-70b-versatile"
GROQ_API_URL="https://api.groq.com/openai/v1/chat/completions"

# JWT_SECRET must be a long random secret in production. Do not use this
# placeholder outside local development. Production startup requires at least
# 32 characters.
JWT_SECRET="replace_me_with_a_long_random_secret"

# ---------------------------------------------------------------------------
# Production example values
# ---------------------------------------------------------------------------
#
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/openme?sslmode=require"
# NODE_ENV="production"
# WEB_URL="https://your-openme-web.vercel.app"
# API_URL="https://your-openme-api.example.com"
# NEXT_PUBLIC_API_URL="https://your-openme-api.example.com"
# AI_ENABLED="false"
# AI_SERVICE_URL="https://your-openme-ai.example.com"
# AI_SERVICE_TOKEN="generate-a-long-random-ai-service-token"
# AI_PROVIDER="mock"
# GROQ_API_KEY=""
# GROQ_MODEL="llama-3.3-70b-versatile"
# GROQ_API_URL="https://api.groq.com/openai/v1/chat/completions"
# JWT_SECRET="generate-a-long-random-production-secret"
